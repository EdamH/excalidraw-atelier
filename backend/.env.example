# --- Required (pick one connection mode) ---

# Option A: Full connection string (local dev / Docker Compose)
MONGO_URI=mongodb://localhost:27017/excalidraw

# Option B: Individual credentials (production / Kubernetes)
# DB_USERNAME=your-db-user
# DB_PASSWORD=your-db-password
# DB_HOST=your-mongodb-host
# DB_NAME=excalidraw

# --- Required ---
JWT_SECRET=devsecret   # Use `openssl rand -hex 32` in production

# --- Optional ---
ADMIN_EMAILS=alice@team.com
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
ENABLE_COLLAB=true
NODE_ENV=development
